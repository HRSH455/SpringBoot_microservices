{
  "id": null,
  "uid": "http-metrics",
  "title": "HTTP Metrics",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Server Request Duration (p95)",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le, uri, status))",
          "legendFormat": "{{uri}} {{status}}",
          "refId": "A"
        }
      ]
    }
  ]
}

